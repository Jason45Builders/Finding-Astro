{
  "name": "finding-astro-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "src/App.tsx",
  "scripts": {
    "dev": "node ../../node_modules/expo/bin/cli start",
    "start": "node ../../node_modules/expo/bin/cli start",
    "android": "node ../../node_modules/expo/bin/cli run:android",
    "ios": "node ../../node_modules/expo/bin/cli run:ios",
    "web": "node ../../node_modules/expo/bin/cli start --web",
    "typecheck": "node ../../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "bundle:check": "node ../../node_modules/expo/bin/cli export --platform android --platform ios --no-bytecode --output-dir .expo-export",
    "build:android": "node ../../node_modules/eas-cli/bin/run build --platform android",
    "build:ios": "node ../../node_modules/eas-cli/bin/run build --platform ios"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.1",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.9.26",
    "@reduxjs/toolkit": "^2.2.7",
    "expo": "~51.0.39",
    "expo-constants": "^16.0.2",
    "expo-image-manipulator": "~12.0.5",
    "expo-image-picker": "^15.0.7",
    "expo-linking": "^6.3.1",
    "expo-location": "^17.0.1",
    "expo-notifications": "0.28.19",
    "i18next": "^23.12.2",
    "react": "^18.2.0",
    "react-i18next": "^14.1.3",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-localize": "^3.2.0",
    "react-native-maps": "1.14.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-redux": "^9.1.2",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "babel-preset-expo": "^11.0.14",
    "eas-cli": "~20.3.0",
    "typescript": "~5.3.3"
  }
}
