{
  "version": 2,
  "buildCommand": "cd backend && npm install && npm run build",
  "installCommand": "cd backend && npm install",
  "functions": {
    "backend/api/index.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/backend/api/index.js"
    }
  ]
}
