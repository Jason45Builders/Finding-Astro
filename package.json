{
  "name": "finding-astro",
  "version": "1.0.0",
  "private": true,
  "description": "Finding Astro — civic animal welfare platform for Chennai",
  "workspaces": [
    "backend",
    "apps/admin-dashboard",
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev:backend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:dashboard": "npm --workspace apps/admin-dashboard run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace backend run build",
    "build:backend": "npm --workspace backend run build",
    "build:dashboard": "npm --workspace apps/admin-dashboard run build",
    "build:web": "npm --workspace apps/web run build",
    "start": "npm --workspace backend run start",
    "vercel-build": "npm --workspace backend run build"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
